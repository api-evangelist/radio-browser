          "info": {
            "name": "List All Stations",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://de1.api.radio-browser.info/json/stations",
            "params": [
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Starting offset for pagination."
              },
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum rows to return."
              },
              {
                "name": "hidebroken",
                "value": "",
                "type": "query",
                "description": "Exclude stations whose last health check failed."
              }
            ]
          },
          "docs": "Return the full collection of radio stations as JSON."
        },
